CREATE TABLE agencias (
    id INTEGER,
    nombre VARCHAR(150) NOT NULL,
    pais VARCHAR(150) NOT NULL,
    fecha_fundacion DATE NOT NULL,
    autor_examen VARCHAR(150) NOT NULL,

    CONSTRAINT pk_id_agencia PRIMARY KEY(id),
    CONSTRAINT uq_nombre_agencia UNIQUE(nombre),
    CONSTRAINT nn_fecha_fundacion CHECK(fecha_fundacion IS NOT NULL)
);


CREATE TABLE satelites (
    id INTEGER,
    nombre VARCHAR(150) NOT NULL,
    orbita VARCHAR(150) NOT NULL,
    peso VARCHAR(150) NOT NULL,
    coste NUMERIC(10,2) NOT NULL,
    activo BOOLEAN NOT NULL,
    fecha_lanzamiento DATE NOT NULL,
    agencia_id INTEGER NOT NULL,
    autor_examen VARCHAR(150) NOT NULL,

    CONSTRAINT pk_id_satelite PRIMARY KEY(id),
    CONSTRAINT fk_id_agencias_satelites
        FOREIGN KEY (agencia_id)
        REFERENCES agencias(id),
    CONSTRAINT uq_nombre_satelite UNIQUE(nombre),
    CONSTRAINT ck_coste CHECK(coste >= 0),
    CONSTRAINT nn_peso CHECK(peso IS NOT NULL),
    CONSTRAINT nn_lanzamiento CHECK(fecha_lanzamiento IS NOT NULL)
);


CREATE TABLE detalle_satelite (
    id INTEGER,
    velocidad_maxima VARCHAR(150) NOT NULL,
    combustible VARCHAR(150) NOT NULL,
    vida_util VARCHAR(150) NOT NULL,
    temperatura_maxima VARCHAR(150) NOT NULL,
    satelite_id INTEGER NOT NULL,
    autor_examen VARCHAR(150) NOT NULL,

    CONSTRAINT pk_id_detalle_satelite PRIMARY KEY(id),
    CONSTRAINT fk_id_satelites_detalle_satelite
        FOREIGN KEY (satelite_id)
        REFERENCES satelites(id),
    CONSTRAINT uq_satelite_detalle UNIQUE(satelite_id)
);
